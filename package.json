{
  "name": "sharedworld",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend"
  ],
  "scripts": {
    "test": "bun test packages/shared packages/backend",
    "test:backend": "bun test packages/backend",
    "test:shared": "bun test packages/shared",
    "test:mod": "JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64 GRADLE_USER_HOME=/tmp/sharedworld-gradle bash ./gradlew --no-daemon -p packages/fabric test",
    "build:mod": "JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64 GRADLE_USER_HOME=/tmp/sharedworld-gradle bash ./gradlew --no-daemon -p packages/fabric remapJar",
    "typecheck": "bun x tsc -p packages/shared/tsconfig.json && bun x tsc -p packages/shared/test/tsconfig.json && bun x tsc -p packages/backend/tsconfig.json && bun x tsc -p packages/backend/test/tsconfig.json",
    "lint": "bun x eslint \"packages/{shared,backend}/{src,test}/**/*.ts\"",
    "check": "bun run typecheck && bun run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "bun-types": "^1.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
